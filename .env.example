# Claude Code Go Configuration
# Required fields must be set for the application to work

# Required: API Key for your LLM provider
CLAUDE_CODE_API_KEY=

# Required: Base URL for your LLM provider API
# Examples:
#   OpenAI: https://api.openai.com/v1
#   Local (Ollama): http://localhost:11434/v1
CLAUDE_CODE_BASE_URL=https://api.openai.com/v1

# Required: Model to use
CLAUDE_CODE_MODEL=gpt-4

# Optional: Model for summary/compact operations (defaults to CLAUDE_CODE_MODEL)
# Using a smaller/faster model for summaries can reduce costs
CLAUDE_CODE_SUMMARY_MODEL=

# Optional: Application name
CLAUDE_CODE_APP_NAME=Claude-Go

# Optional: Maximum turns per conversation (0 = unlimited)
CLAUDE_CODE_MAX_TURNS=24

# Optional: Session directory for storing conversations
# CLAUDE_CODE_SESSION_DIR=.claude-go/sessions

# Optional: System prompt override
CLAUDE_CODE_SYSTEM_PROMPT=

# Optional: MCP configuration file path
CLAUDE_CODE_MCP_CONFIG=.claude-go/mcp.json

# Optional: Plugins configuration file path
CLAUDE_CODE_PLUGINS_CONFIG=.claude-go/plugins.json

# Optional: Hooks configuration file path
CLAUDE_CODE_HOOKS_CONFIG=.claude-go/hooks.json

# Optional: Enable/disable auto-compact (default: true)
CLAUDE_CODE_AUTO_COMPACT=true

# Optional: Override context window size for models with different limits
# CLAUDE_CODE_CONTEXT_WINDOW=200000
